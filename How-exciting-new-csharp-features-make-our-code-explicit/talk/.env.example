# slidev-polls config. These change per talk / per poll, so they are NOT committed.
# Copy this file to talk/.env.local (git-ignored) and fill in your real values
# before the talk. See README → Poll runbook.

# Backend host — an ephemeral Cloudflare tunnel URL that changes every talk.
VITE_POLL_SERVER=https://polls.example.com

# Poll identity — from the slidev-polls admin "Copy snippet" (per created poll).
# slug is the stable poll name; keep it in sync with the <PollQr> tag in slides.md.
VITE_POLL_SLUG=csharp15
VITE_POLL_ID=00000000-0000-0000-0000-000000000000
VITE_POLL_QUESTION_ID=00000000-0000-0000-0000-000000000000
